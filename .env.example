# --- Database ---
# Local Postgres. Adjust user/password/host to match your instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gatehouse?schema=public"

# --- Nomba API (https://developer.nomba.com) ---
# Use https://sandbox.nomba.com while testing, https://api.nomba.com in production.
NOMBA_BASE_URL="https://sandbox.nomba.com"
NOMBA_CLIENT_ID=""
NOMBA_CLIENT_SECRET=""
NOMBA_ACCOUNT_ID=""            # parent account id (UUID), sent as the `accountId` header
NOMBA_WEBHOOK_SIGNATURE_KEY="" # signature key configured on the Nomba dashboard webhook

# --- App ---
APP_BASE_URL="http://localhost:3000"   # used to build resident links
SESSION_SECRET=""                       # >=32 chars; encrypts the session cookie

# --- Notifications (optional; logged if unset) ---
NOTIFY_PROVIDER=""   # e.g. "termii" | "twilio" | leave blank to just log
NOTIFY_API_KEY=""
