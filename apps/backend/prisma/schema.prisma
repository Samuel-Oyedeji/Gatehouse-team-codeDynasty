// Gatehouse — Prisma Schema (v5)
// Clean Architecture | Estate Management Backend
//
// Money is stored as integer kobo everywhere (fields end in `Kobo`); naira
// formatting happens only at the API edge (see src/common/money.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum FeeType {
  service_fee
  levy
}

enum FeeFrequency {
  monthly
  quarterly
  yearly
  one_time
}

enum OccupantType {
  owner
  tenant
}

enum AllocationRule {
  OLDEST_FIRST
  DUES_FIRST
}

enum UnitStatus {
  PAID
  PARTIAL
  OVERDUE
  UNBILLED
  CREDIT
}

enum ChargeStatus {
  OPEN
  PARTIAL
  SETTLED
}

enum PaymentStatus {
  MATCHED
  PARTIAL
  OVERPAYMENT
  EXCEPTION
  MANUAL
  REVERSED
}

enum ExceptionType {
  OVERPAYMENT
  DUPLICATE
  MISDIRECTED
  THIRD_PARTY
  REVERSAL
}

enum ExceptionStatus {
  OPEN
  RESOLVED
}

enum PayoutStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

// ─────────────────────────────────────────────────────────────────────────────
// Manager — Estate manager or treasurer
// ─────────────────────────────────────────────────────────────────────────────

model Manager {
  id             String    @id @default(uuid()) @db.Uuid
  fullName       String
  email          String    @unique
  phone          String?
  hashedPassword String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  estates Estate[]

  @@index([email])
  @@index([id])
  @@index([fullName])
  @@map("managers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Estate — Residential estate managed by a Manager
// ─────────────────────────────────────────────────────────────────────────────

model Estate {
  id                      String         @id @default(uuid()) @db.Uuid
  managerId               String         @db.Uuid
  name                    String
  address                 String
  city                    String
  state                   String
  units                   Int // total number of units
  cycleLabel              String?        // current billing cycle, e.g. "Q3 2026"
  allocationRule          AllocationRule @default(OLDEST_FIRST)
  autoCreditThresholdKobo Int            @default(0) // surplus above this raises an exception
  duplicateWindowSecs     Int            @default(900) // 15 minutes
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  deletedAt               DateTime?

  manager     Manager      @relation(fields: [managerId], references: [id])
  fees        Fee[]
  Unit        Unit[]
  unitGroups  UnitGroup[]
  billingRuns BillingRun[]
  payments    Payment[]
  vendors     Vendor[]
  payouts     Payout[]
  activity    Activity[]

  @@index([name])
  @@index([id])
  @@map("estates")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fee — Service charge / levy definition (the fee structure) for an estate
// ─────────────────────────────────────────────────────────────────────────────

model Fee {
  id           String       @id @default(uuid()) @db.Uuid
  estateId     String       @db.Uuid
  name         String
  type         FeeType
  amountKobo   Int
  frequency    FeeFrequency
  requireExact Boolean      @default(false) // for levies that must be paid exactly
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  estate  Estate   @relation(fields: [estateId], references: [id])
  charges Charge[]

  @@index([id])
  @@index([name])
  @@index([type])
  @@map("fees")
}

// ─────────────────────────────────────────────────────────────────────────────
// Unit — Individual units within an estate
// ─────────────────────────────────────────────────────────────────────────────

model Unit {
  id                String       @id @default(uuid()) @db.Uuid
  estateId          String       @db.Uuid
  block             String
  groupId           String?      @db.Uuid // user-defined group; null = ungrouped
  unitName          String // e.g. A1, B3
  occupant          String
  phone             String?
  email             String
  type              OccupantType // owner | tenant
  balanceKobo       Int          @default(0)
  creditBalanceKobo Int          @default(0)
  status            UnitStatus   @default(UNBILLED)
  lastPaymentAt     DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  estate        Estate        @relation(fields: [estateId], references: [id])
  group         UnitGroup?    @relation(fields: [groupId], references: [id])
  account       Account?
  charges       Charge[]
  payments      Payment[]
  creditEntries CreditEntry[]
  residentLink  ResidentLink?

  @@index([id])
  @@index([unitName])
  @@index([email])
  @@index([groupId])
  @@map("units")
}

// ─────────────────────────────────────────────────────────────────────────────
// UnitGroup — a manager-defined grouping of units (replaces the fixed A/B/C/D
// blocks in the UI). A unit belongs to at most one group; deleting a group
// reverts its units to ungrouped (groupId → null) via the default SetNull.
// ─────────────────────────────────────────────────────────────────────────────

model UnitGroup {
  id        String   @id @default(uuid()) @db.Uuid
  estateId  String   @db.Uuid
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estate Estate @relation(fields: [estateId], references: [id])
  units  Unit[]

  @@index([estateId])
  @@map("unit_groups")
}

// ─────────────────────────────────────────────────────────────────────────────
// Account — Virtual bank account from Nomba, linked to a Unit
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id            String    @id @default(uuid()) @db.Uuid
  unitId        String    @unique @db.Uuid
  accountNumber String
  accountName   String // e.g. Unit-A1
  bankName      String
  accountRef    String    @unique // Nomba accountRef used at creation
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([id])
  @@index([accountName])
  @@index([accountNumber])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// BillingRun — a batch that bills one service charge per selected unit
// ─────────────────────────────────────────────────────────────────────────────

model BillingRun {
  id              String   @id @default(uuid()) @db.Uuid
  estateId        String   @db.Uuid
  cycleLabel      String
  chargeAmountKobo Int
  unitScope       Json // { all: true } or { unitIds: [...] }
  createdAt       DateTime @default(now())

  estate  Estate   @relation(fields: [estateId], references: [id])
  charges Charge[]

  @@index([estateId])
  @@map("billing_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Charge — a billed instance a unit owes (service charge or levy)
// ─────────────────────────────────────────────────────────────────────────────

model Charge {
  id                 String       @id @default(uuid()) @db.Uuid
  unitId             String       @db.Uuid
  sourceType         FeeType
  feeId              String?      @db.Uuid
  billingRunId       String?      @db.Uuid
  description        String
  cycleLabel         String
  originalAmountKobo Int
  outstandingKobo    Int
  dueDate            DateTime
  status             ChargeStatus @default(OPEN)
  createdAt          DateTime     @default(now())

  unit        Unit         @relation(fields: [unitId], references: [id])
  fee         Fee?         @relation(fields: [feeId], references: [id])
  billingRun  BillingRun?  @relation(fields: [billingRunId], references: [id])
  allocations Allocation[]

  @@index([unitId])
  @@index([status])
  @@map("charges")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payment — an inbound transfer into a unit's virtual account (or manual)
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  estateId        String        @db.Uuid
  unitId          String?       @db.Uuid
  nombaTxnRef     String        @unique // idempotency key
  grossAmountKobo Int
  sourceName      String
  sourceAccount   String?
  sourceBankCode  String?
  receivedAt      DateTime      @default(now())
  status          PaymentStatus
  tag             String?
  rawPayload      Json?
  createdAt       DateTime      @default(now())

  estate      Estate       @relation(fields: [estateId], references: [id])
  unit        Unit?        @relation(fields: [unitId], references: [id])
  allocations Allocation[]
  exception   Exception?

  @@index([estateId])
  @@index([unitId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Allocation — how much of a payment was applied to which charge
// ─────────────────────────────────────────────────────────────────────────────

model Allocation {
  id         String   @id @default(uuid()) @db.Uuid
  paymentId  String   @db.Uuid
  chargeId   String   @db.Uuid
  amountKobo Int
  createdAt  DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  charge  Charge  @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([chargeId])
  @@map("allocations")
}

// ─────────────────────────────────────────────────────────────────────────────
// CreditEntry — surplus held (or consumed) against a unit
// ─────────────────────────────────────────────────────────────────────────────

model CreditEntry {
  id         String   @id @default(uuid()) @db.Uuid
  unitId     String   @db.Uuid
  amountKobo Int // positive = credit added, negative = credit consumed
  reason     String
  createdAt  DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("credit_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Exception — a payment that needs a human decision
// ─────────────────────────────────────────────────────────────────────────────

model Exception {
  id              String          @id @default(uuid()) @db.Uuid
  paymentId       String          @unique @db.Uuid
  type            ExceptionType
  suggestion      String
  candidateUnitId String?         @db.Uuid
  status          ExceptionStatus @default(OPEN)
  resolvedAt      DateTime?
  resolutionNote  String?
  createdAt       DateTime        @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("exceptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Vendor — an estate supplier paid via Nomba transfers
// ─────────────────────────────────────────────────────────────────────────────

model Vendor {
  id            String    @id @default(uuid()) @db.Uuid
  estateId      String    @db.Uuid
  name          String
  category      String
  bankName      String
  bankCode      String?
  accountNumber String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  estate  Estate   @relation(fields: [estateId], references: [id])
  payouts Payout[]

  @@index([estateId])
  @@map("vendors")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payout — an outbound transfer to a vendor via Nomba Transfers
// ─────────────────────────────────────────────────────────────────────────────

model Payout {
  id            String       @id @default(uuid()) @db.Uuid
  estateId      String       @db.Uuid
  vendorId      String       @db.Uuid
  amountKobo    Int
  note          String
  merchantTxRef String       @unique // idempotency key sent to Nomba
  nombaTxnRef   String?
  status        PayoutStatus @default(PENDING)
  createdAt     DateTime     @default(now())

  estate Estate @relation(fields: [estateId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([estateId])
  @@index([vendorId])
  @@map("payouts")
}

// ─────────────────────────────────────────────────────────────────────────────
// ResidentLink — tokenised no-login statement link for a unit
// ─────────────────────────────────────────────────────────────────────────────

model ResidentLink {
  id           String    @id @default(uuid()) @db.Uuid
  unitId       String    @unique @db.Uuid
  token        String    @unique
  createdAt    DateTime  @default(now())
  lastViewedAt DateTime?

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("resident_links")
}

// ─────────────────────────────────────────────────────────────────────────────
// Activity — dashboard activity feed
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(uuid()) @db.Uuid
  estateId  String   @db.Uuid
  message   String
  unitId    String?  @db.Uuid
  createdAt DateTime @default(now())

  estate Estate @relation(fields: [estateId], references: [id])

  @@index([estateId])
  @@map("activity")
}
