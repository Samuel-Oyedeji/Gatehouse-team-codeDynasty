DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gatehouse?schema=public
# Direct (non-pooled) connection — used by Prisma for migrations. With poolers
# like PgBouncer/Supabase, point DATABASE_URL at the pooler and DIRECT_URL at
# the direct connection. Locally this can be the same value as DATABASE_URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/gatehouse?schema=public
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Nomba — use a VERSION-LESS base URL; the client adds /v1 and /v2 per endpoint.
NOMBA_BASE_URL=https://sandbox.nomba.com
# Parent accountId, sent as the `accountId` header on every call.
NOMBA_ACCOUNT_ID=your-parent-account-uuid
# YOUR sub-account id (the one Nomba emailed your team). Virtual accounts are
# created UNDER this sub-account so inbound funds settle to you, not the mothership.
# Leave blank to fall back to the parent-level virtual-account endpoint.
NOMBA_SUB_ACCOUNT_ID=your-sub-account-id
NOMBA_CLIENT_ID=your-client-id
NOMBA_CLIENT_SECRET=your-client-secret
# Signature key configured on the Nomba dashboard webhook (HmacSHA256 verification).
NOMBA_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key

APP_BASE_URL=http://localhost:3000
PORT=3000
